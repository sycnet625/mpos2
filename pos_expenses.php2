            </div>
        </div>
    </div>
</div>

<script>
async function saveExpense(e) { e.preventDefault(); const id = document.getElementById('inputId').value; const action = id ? 'update' : 'create'; const formData = new FormData(document.getElementById('formExpense')); const data = Object.fromEntries(formData.entries()); if(id) data.id = id; if(!confirm(id ? '¿Guardar cambios?' : '¿Registrar este gasto?')) return; try { const res = await fetch(`?action=${action}`, { method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify(data) }); const json = await res.json(); if(json.status === 'success') { alert(json.msg); location.reload(); } else { alert('Error: ' + json.msg); } } catch(err) { alert('Error de conexión'); } }
async function deleteExpense(id) { if(!confirm('¿Estás seguro de ELIMINAR este gasto?')) return; try { const res = await fetch('?action=delete', { method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify({id: id}) }); const json = await res.json(); if(json.status === 'success') { document.getElementById(`row-${id}`).remove(); } else { alert('Error: ' + json.msg); } } catch(err) { alert('Error de conexión'); } }
function editExpense(gasto) { document.getElementById('inputId').value = gasto.id; document.getElementById('inputFecha').value = gasto.fecha.split(' ')[0]; document.getElementById('inputConcepto').value = gasto.concepto; document.getElementById('inputMonto').value = gasto.monto; document.getElementById('inputCat').value = gasto.categoria; document.getElementById('inputTipo').value = gasto.tipo; document.getElementById('btnSave').innerHTML = '<i class="fas fa-sync me-2"></i> ACTUALIZAR'; document.getElementById('btnSave').classList.replace('btn-success', 'btn-primary'); document.getElementById('btnCancel').classList.remove('d-none'); document.getElementById('formExpense').scrollIntoView({behavior: 'smooth'}); }
function resetForm() { document.getElementById('formExpense').reset(); document.getElementById('inputId').value = ''; document.getElementById('btnSave').innerHTML = '<i class="fas fa-save me-2"></i> GUARDAR GASTO'; document.getElementById('btnSave').classList.replace('btn-primary', 'btn-success'); document.getElementById('btnCancel').classList.add('d-none'); }
function fillTemplate(concepto, monto, cat) { resetForm(); document.getElementById('inputConcepto').value = concepto; document.getElementById('inputMonto').value = monto; document.getElementById('inputCat').value = cat; document.getElementById('inputTipo').value = 'FIJO'; }

// --- Modal: Gastos del Día ---
function showDailyExpensesModal() {
    const fecha = document.getElementById('inputFecha').value || '<?php echo date("Y-m-d"); ?>';
    const gastos = <?php echo json_encode($gastos); ?>;
    const delDia = gastos.filter(g => g.fecha && g.fecha.startsWith(fecha));
    let total = 0;
    let html = '<table class="table table-sm table-striped mb-0"><thead><tr><th>Concepto</th><th>Categ.</th><th class="text-end">Monto</th></tr></thead><tbody>';
    if(delDia.length === 0) {
        html += '<tr><td colspan="3" class="text-center text-muted py-3">Sin gastos para ' + fecha + '</td></tr>';
    } else {
        delDia.forEach(g => {
            total += parseFloat(g.monto);
            html += `<tr><td>${g.concepto}</td><td><span class="badge bg-light text-dark border">${g.categoria}</span></td><td class="text-end fw-bold text-danger">-$${parseFloat(g.monto).toFixed(2)}</td></tr>`;
        });
    }
    html += `</tbody><tfoot><tr class="table-danger"><td colspan="2" class="fw-bold">TOTAL DEL DÍA</td><td class="text-end fw-bold">-$${total.toFixed(2)}</td></tr></tfoot></table>`;
    showGenericModal('Gastos del ' + fecha, html);
}

// --- Modal: Plantillas ---
function showTemplatesModal() {
    const plantillas = <?php echo json_encode($plantillas); ?>;
    let html = '<div class="list-group">';
    plantillas.forEach(p => {
        html += `<button class="list-group-item list-group-item-action d-flex justify-content-between align-items-center" onclick="fillTemplate('${p.concepto}', ${p.monto}, '${p.cat}'); bootstrap.Modal.getInstance(document.getElementById('genericModal')).hide();">
            <div><i class="fas fa-file-alt me-2 text-muted"></i><strong>${p.concepto}</strong> <span class="badge bg-light text-dark border ms-2">${p.cat}</span></div>
            <span class="fw-bold text-success">$${parseFloat(p.monto).toFixed(2)}</span>
        </button>`;
    });
    html += '</div><p class="text-muted small mt-2 mb-0"><i class="fas fa-info-circle me-1"></i>Haz clic en una plantilla para rellenar el formulario.</p>';
    showGenericModal('Plantillas Rápidas', html);
}

// --- Modal: Copiar Mes Anterior ---
function showCopyPreviousMonthModal() {
    const mesActual = <?php echo intval($mesActual); ?>;
    const anioActual = <?php echo intval($anioActual); ?>;
    let mesAnt = mesActual - 1, anioAnt = anioActual;
    if(mesAnt === 0) { mesAnt = 12; anioAnt--; }
    const meses = ['','Ene','Feb','Mar','Abr','May','Jun','Jul','Ago','Sep','Oct','Nov','Dic'];
    let html = `<p>Esto copiará todos los gastos <strong>FIJOS</strong> de <strong>${meses[mesAnt]} ${anioAnt}</strong> al mes actual (<strong>${meses[mesActual]} ${anioActual}</strong>).</p>
    <p class="text-muted small"><i class="fas fa-info-circle me-1"></i>Solo se copian gastos de tipo FIJO. Las fechas se ajustan al mes actual.</p>
    <button class="btn btn-primary w-100 fw-bold" onclick="executeCopyPreviousMonth(${mesAnt}, ${anioAnt})"><i class="fas fa-copy me-2"></i>Copiar Gastos Fijos</button>`;
    showGenericModal('Copiar Mes Anterior', html);
}

async function executeCopyPreviousMonth(mesAnt, anioAnt) {
    const gastos = <?php echo json_encode($gastos); ?>;
    const fijos = gastos.filter(g => g.tipo === 'FIJO' && g.fecha);
    // Filtrar solo los del mes anterior
    const delMesAnt = fijos.filter(g => {
        const d = new Date(g.fecha);
        return (d.getMonth()+1) === mesAnt && d.getFullYear() === anioAnt;
    });
    if(delMesAnt.length === 0) {
        alert('No se encontraron gastos fijos en el mes anterior.');
        return;
    }
    if(!confirm(`Se copiarán ${delMesAnt.length} gastos fijos. ¿Continuar?`)) return;
    let ok = 0;
    for(const g of delMesAnt) {
        const fechaOrig = new Date(g.fecha);
        let dia = fechaOrig.getDate();
        const mesActual = <?php echo intval($mesActual); ?>;
        const anioActual = <?php echo intval($anioActual); ?>;
        const maxDia = new Date(anioActual, mesActual, 0).getDate();
        if(dia > maxDia) dia = maxDia;
        const nuevaFecha = `${anioActual}-${String(mesActual).padStart(2,'0')}-${String(dia).padStart(2,'0')}`;
        try {
            const res = await fetch('?action=create', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({
                fecha: nuevaFecha, concepto: g.concepto, monto: g.monto, categoria: g.categoria, tipo: 'FIJO', notas: 'Copiado de ' + g.fecha
            })});
            const json = await res.json();
            if(json.status === 'success') ok++;
        } catch(e) {}
    }
    alert(`${ok} gastos copiados exitosamente.`);
    location.reload();
}

// --- Modal Genérico Reutilizable ---
function showGenericModal(title, bodyHtml) {
    let modal = document.getElementById('genericModal');
    if(!modal) {
        modal = document.createElement('div');
        modal.id = 'genericModal';
        modal.className = 'modal fade';
        modal.tabIndex = -1;
        modal.innerHTML = `<div class="modal-dialog modal-dialog-centered"><div class="modal-content shadow">
            <div class="modal-header py-2"><h6 class="modal-title fw-bold" id="genericModalTitle"></h6><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
            <div class="modal-body" id="genericModalBody"></div>
        </div></div>`;
        document.body.appendChild(modal);
    }
    document.getElementById('genericModalTitle').innerText = title;
    document.getElementById('genericModalBody').innerHTML = bodyHtml;
    new bootstrap.Modal(modal).show();
}
</script>
