            <div class="card shadow-sm border-0 mb-4"><div class="card-header bg-light"><small class="fw-bold text-muted">PLANTILLAS RÁPIDAS</small></div><div class="card-body p-2"><div class="d-flex flex-wrap gap-2"><?php foreach($plantillas as $p): ?><button class="btn btn-outline-secondary btn-sm" onclick="fillTemplate('<?php echo $p['concepto']; ?>', <?php echo $p['monto']; ?>, '<?php echo $p['cat']; ?>')"><i class="fas fa-copy me-1"></i> <?php echo $p['concepto']; ?></button><?php endforeach; ?></div></div></div>
        </div>

