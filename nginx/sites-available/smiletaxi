server {
    listen 80;
    server_name 3.94.162.45;
    root /var/www/palweb/;
    index index.php index.html;

    location / {
        try_files $uri $uri/ /index.php?$query_string;
    }

    # Procesar PHP con FPM (Súper rápido)
    location ~ \.php$ {
        include snippets/fastcgi-php.conf;
        fastcgi_pass unix:/run/php/php8.3-fpm.sock;
    }

    # Bloquear acceso a archivos ocultos (.git, .env)
    location ~ /\.ht {
        deny all;
    }
}

