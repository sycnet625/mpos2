{
  "name": "snmp-vu-desktop",
  "version": "1.0.6",
  "description": "Desktop Windows gadget with 5 analog SNMP traffic gauges",
  "main": "main.js",
  "author": "PalWeb",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "pack-win": "electron-builder --win portable"
  },
  "build": {
    "appId": "net.palweb.snmpvu",
    "productName": "PalWeb SNMP VU",
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "icon": "assets/icon.ico",
      "signAndEditExecutable": false,
      "verifyUpdateCodeSignature": false,
      "target": [
        "portable"
      ]
    },
    "portable": {
      "artifactName": "SNMP-VU-Monitor-${version}.exe"
    }
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "net-snmp": "^3.12.0"
  },
  "devDependencies": {
    "electron": "^31.3.1",
    "electron-builder": "^24.13.3"
  }
}
