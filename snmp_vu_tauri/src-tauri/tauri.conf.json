{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "PalWeb SNMP VU Tauri",
    "version": "1.0.0",
    "identifier": "net.palweb.snmpvu.tauri",
    "build": {
        "frontendDist": "../src"
    },
    "app": {
        "withGlobalTauri": true,
        "windows": [
            {
                "label": "main",
                "title": "PalWeb SNMP VU Tauri",
                "width": 192,
                "height": 980,
                "minWidth": 140,
                "minHeight": 760,
                "decorations": false,
                "alwaysOnTop": true,
                "resizable": false,
                "transparent": false,
                "center": true,
                "visible": true
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/icon.png",
            "icons/icon.ico"
        ]
    }
}
